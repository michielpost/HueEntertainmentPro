@page "/bridges"
@using HueEntertainmentPro.Shared.Models
@using HueEntertainmentPro.Shared.Models.Requests
@using HueEntertainmentPro.Shared.Interfaces
@inject IBridgeDataService BridgeDataService
@inject NavigationManager Navigation
@inject IDialogService DialogService

<PageTitle>Bridges</PageTitle>

<h1>Bridges</h1>

<div class="page-actions">
    <FluentButton @onclick="OpenAddDialog" Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size16.Add())">Add Bridge</FluentButton>
</div>

@if (bridges == null)
{
    <FluentStack Orientation="Orientation.Vertical" Gap="16" HorizontalAlignment="HorizontalAlignment.Center" Style="padding-top: 2rem;">
        <FluentProgressRing />
        <FluentLabel Typo="Typography.Body">Loading bridges...</FluentLabel>
    </FluentStack>
}
else if (!bridges.Any())
{
    <FluentCard Class="page-card" MinimalStyle="true">
        <div class="empty-state">
            <FluentIcon Value="@(new Icons.Regular.Size48.Lightbulb())" Color="Color.Disabled" />
            <h3>No bridges yet</h3>
            <FluentLabel Typo="Typography.Body">Add your first Hue Bridge to get started. Make sure your bridge is connected to the same network.</FluentLabel>
            <FluentButton @onclick="OpenAddDialog" Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size16.Add())">Add Bridge</FluentButton>
        </div>
    </FluentCard>
}
else
{
    <FluentCard Class="page-card" MinimalStyle="true" Style="padding: 1rem;">
        <FluentDataGrid Id="bridgegrid" Items="@bridges" GridTemplateColumns="2fr 2fr 2fr auto" TGridItem="Bridge" RowSize="DataGridRowSize.Medium">
            <TemplateColumn Title="Name" Sortable="true" Align="Align.Start">
                <NavLink href="@($"/bridge/{context.Id}")">@context.Name</NavLink>
            </TemplateColumn>
            <PropertyColumn Title="IP" Property="@(b => b.Ip)" Sortable="true" Align="Align.Start" />
            <PropertyColumn Title="Id" Property="@(b => b.Id)" Sortable="true" Align="Align.Start" />
            <TemplateColumn Title="" Align="Align.End">
                <NavLink href="@($"/bridge/{context.Id}")" title="Edit">
                    <FluentIcon Value="@(new Icons.Regular.Size16.Edit())" />
                </NavLink>
            </TemplateColumn>
        </FluentDataGrid>
    </FluentCard>
}


@code {
    private IQueryable<Bridge>? bridges;

    protected override async Task OnInitializedAsync()
    {
        var result = await BridgeDataService.GetBridges();
        bridges = result.AsQueryable();
    }

    private async Task OpenAddDialog()
    {
        var dialog = await DialogService.ShowDialogAsync<AddBridgeDialog>(new DialogParameters()
        {
            Title = $"Add a bridge",
            OnDialogResult = DialogService.CreateDialogCallback(this, HandleDialog),
        });

    }

    private async Task HandleDialog(DialogResult result)
    {
        await OnInitializedAsync();
        StateHasChanged();
    }

    private void NavigateToBridgeDetails(Guid id)
    {
        Navigation.NavigateTo($"/bridge/{id}");
    }
}

